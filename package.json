{
  "name": "@jaepil/usqldb",
  "version": "0.1.0",
  "description": "PostgreSQL 17-compatible information_schema and pg_catalog for UQA",
  "license": "AGPL-3.0-only",
  "author": "Jaepil Jeong <jaepil@cognica.io>",
  "repository": {
    "type": "git",
    "url": "https://github.com/cognica-io/usqldb-js"
  },
  "keywords": [
    "postgresql",
    "information-schema",
    "pg-catalog",
    "uqa",
    "sql",
    "compatibility",
    "browser"
  ],
  "type": "module",
  "main": "dist/usqldb.umd.js",
  "module": "dist/usqldb.es.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/usqldb.es.js",
      "require": "./dist/usqldb.umd.js"
    }
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --noEmit && vite build && tsc -p tsconfig.build.json --emitDeclarationOnly --declarationDir dist/types --outDir dist/types",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@jaepil/uqa": "^0.2.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
